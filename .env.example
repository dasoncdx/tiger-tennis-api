# 数据库连接（填入Zeabur PostgreSQL连接串）
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# JWT密钥（生产环境请改成随机32位字符串）
JWT_SECRET="tiger-tennis-dev-secret-change-in-production"

# 服务端口
PORT=3001

# Cloudflare R2（后续配置）
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="tiger-tennis"
R2_PUBLIC_URL=""
